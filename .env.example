# Xiaohongshu
XHS_INBOX_URL=https://www.xiaohongshu.com
XHS_BROWSER_CHANNEL=msedge
XHS_HEADLESS=false
XHS_POLL_INTERVAL_MS=20000
XHS_MAX_CONVERSATIONS=20
XHS_AUTO_SEND_REPLY=false
XHS_MIN_REPLY_INTERVAL_MINUTES=30
XHS_REPLY_COOLDOWN_MINUTES=30
XHS_MESSAGE_HISTORY_LIMIT=8
XHS_MANUAL_REVIEW_KEYWORDS=合作,商务,联名,达人,投放,报价,多少钱,怎么收费,收费标准,预算,价格,退款,投诉,举报,侵权,律师,起诉,维权,差评,加微信,微信,vx,手机号,电话,联系方式

# LLM
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.4
LLM_SYSTEM_PROMPT=你是个人小红书账号的私信助理。请用简洁、礼貌、像真人的中文回复，不承诺做不到的事，不输出 markdown，不要显得像机器人。

# Feishu bot delivery
# Long-connection Feishu app bots should prefer app mode.
FEISHU_MODE=app
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx
FEISHU_RECEIVE_ID=ou_xxxxx
FEISHU_RECEIVE_ID_TYPE=open_id

# Optional webhook fallback
FEISHU_WEBHOOK_URL=
# Optional secret for signed webhook bots
FEISHU_WEBHOOK_SECRET=

# Optional selector overrides, separated by ||
# XHS_CONVERSATION_ITEM_SELECTORS=
# XHS_UNREAD_BADGE_SELECTORS=
# XHS_MESSAGE_ROW_SELECTORS=
# XHS_MESSAGE_INPUT_SELECTORS=
# XHS_SEND_BUTTON_SELECTORS=
